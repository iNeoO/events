{
  "name": "@events/backend",
  "type": "module",
  "scripts": {
    "backend:dev": "tsx watch --clear-screen=false src/index.ts",
    "workers:dev": "tsx watch --clear-screen=false src/workers/index.ts",
    "test": "vitest",
    "lint": "biome check",
    "build": "tsc",
    "backend:start": "node dist/index.js",
    "workers:start": "node dist/workers/index.js"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "@events/common": "workspace:*",
    "@events/db": "workspace:*",
    "@events/infra": "workspace:*",
    "@events/services": "workspace:*",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "vitest": "^4.0.18",
    "zod": "catalog:"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./hc": {
      "import": {
        "types": "./dist/libs/hc.d.ts",
        "default": "./dist/libs/hc.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
